{
  "name": "ai-auto-annotator",
  "displayName": "annotator",
  "description": "annotates AI Generated Content",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-auto-annotator.helloWorld",
        "title": "Hello World"
      }
    ],
    "configuration": {
      "title": "AI Annotator",
      "properties": {
        "aiAnnotator.employeeId": {
          "type": "string",
          "default": "DING",
          "description": "Enter your Employee ID for AI code tagging."
        },
        "aiAnnotator.enableCollabMode": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, the extension will track multiple contributors in the same AI block."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:coverage": "vscode-test --coverage --reporter=html --reporter=text"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "nyc": "^18.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "out/test/**"
    ],
    "require": [
      "ts-node/register"
    ],
    "sourceMap": true,
    "instrument": true,
    "all": true,
    "reporter": [
      "text",
      "html"
    ]
  }
}
