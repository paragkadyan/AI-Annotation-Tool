{
  "name": "ai-auto-annotator",
  "displayName": "annotator",
  "description": "annotates AI Generated Content",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-auto-annotator.helloWorld",
        "title": "Hello World"
      }
    ],
    "configuration": {
      "title": "AI Annotator",
      "properties": {
        "aiAnnotator.employeeId": {
          "type": "string",
          "default": "Sri",
          "description": "Enter your Employee ID for AI code tagging."
        },
        "aiAnnotator.enableCollabMode": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, the extension will track multiple contributors in the same AI block."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}